# ============================================================================
# Open Climb Aviation — backend environment template
# Copy this file to `backend/.env` and fill in real values. NEVER commit .env.
#   PowerShell:  Copy-Item .env.example .env
# ============================================================================

# Port the Express server listens on. Render injects its own PORT; keep 5000 locally.
PORT=5000

# ── Supabase (Project Settings → API) ──
# SUPABASE_URL        = the Project URL,    e.g. https://abcdxyz.supabase.co
# SUPABASE_SERVICE_KEY= the *service_role* secret key (NOT the anon key).
#   This key bypasses Row Level Security, so it must stay server-side only.
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Auth ──
# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Razorpay (Dashboard → Settings → API Keys) ──
# Use rzp_test_* keys while testing, swap to rzp_live_* after live KYC is approved.
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (Gmail SMTP via nodemailer) ──
# EMAIL_USER = the full Gmail address that sends mail.
# EMAIL_PASS = a Gmail *App Password* (16 chars), NOT your normal Gmail password.
#
# How to generate a Gmail App Password:
#   1. The account MUST have 2-Step Verification enabled:
#      Google Account -> Security -> 2-Step Verification -> turn ON.
#   2. Go to https://myaccount.google.com/apppasswords
#      (only appears once 2-Step Verification is on).
#   3. App name: type "Open Climb Aviation" -> Create.
#   4. Google shows a 16-character code like "abcd efgh ijkl mnop".
#   5. Paste it here as EMAIL_PASS WITHOUT the spaces: abcdefghijklmnop
#   6. If sending later fails, regenerate the App Password and update this value.
EMAIL_USER=jaykotecha2003@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Frontend / CORS ──
# Public URL of the live frontend. Used for CORS allow-list and email links.
# Local: http://localhost:3000  |  Prod: your Netlify URL or final custom domain.
FRONTEND_URL=http://localhost:3000

# Inbox that receives new-enquiry and new-enrollment admin notifications.
ADMIN_EMAIL=jaykotecha2003@gmail.com
