# ============================================================================
# Open Climb Aviation — backend environment template
# Copy this file to `backend/.env` and fill in real values. NEVER commit .env.
#   PowerShell:  Copy-Item .env.example .env
# ============================================================================

# Port the Express server listens on. Render injects its own PORT; keep 5000 locally.
PORT=5000

# ── Supabase (Project Settings → API) ──
# SUPABASE_URL        = the Project URL,    e.g. https://abcdxyz.supabase.co
# SUPABASE_SERVICE_KEY= the *service_role* secret key (NOT the anon key).
#   This key bypasses Row Level Security, so it must stay server-side only.
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Auth ──
# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Razorpay (Dashboard → Settings → API Keys) ──
# Use rzp_test_* keys while testing, swap to rzp_live_* after live KYC is approved.
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (Resend HTTP API) ──
# We use Resend instead of Gmail SMTP because Render blocks outbound SMTP, so
# nodemailer + Gmail times out with "Connection timeout".
#
# RESEND_API_KEY = an API key from https://resend.com (Dashboard -> API Keys).
#   1. Create a Resend account and verify your login email.
#   2. API Keys -> Create API Key -> copy the value (starts with "re_").
#   3. Paste it here / set it in Render.
#
# Sender: until a custom domain is verified in Resend, mail is sent from the
# default onboarding address "Open Climb Aviation <onboarding@resend.dev>"
# (hard-coded in the routes). Replies route to ADMIN_EMAIL via reply_to.
# To send from your own domain later, verify it in Resend (Domains) and update
# MAIL_FROM in routes/auth.js + routes/payment.js.
RESEND_API_KEY=your_resend_api_key

# NOTE: EMAIL_USER / EMAIL_PASS (Gmail SMTP) are no longer used and can be removed.

# ── Frontend / CORS ──
# Public URL of the live frontend. Used for CORS allow-list and email links.
# Local: http://localhost:3000  |  Prod: your Netlify URL or final custom domain.
FRONTEND_URL=http://localhost:3000

# Inbox that receives new-enquiry and new-enrollment admin notifications,
# and the reply-to address on outgoing mail.
ADMIN_EMAIL=training.ocaa@gmail.com
